# Signing keys
cosign.key
cosign.private

# Container files
/Containerfile

# WinApps sensitive configuration files
# NOTE: The config files ARE tracked with safe placeholder values for builds
# The .template files serve as backups. Users should modify the tracked files locally
# and ensure they don't commit real credentials (check before git add!)
files/home/.config/winapps/*.bak
files/home/.config/winapps/*.bak.bak

# Environment files
.env
.env.*
!.env.example
!.env.template
*.local

