*secret*
*credentials*
*password*
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_dsa
id_ecdsa
id_ed25519

# SSH and GPG
.ssh/
*.gpg

# API keys and tokens
*apikey*
*api_key*
*token*
*oauth*

# Cloud provider credentials
.aws/
.gcp/
.azure/
credentials.json
service-account*.json

# Database credentials
*.db-journal
*.sql.bak

# Backup files that might contain sensitive data
*.bak
*.backup
*.old
*.orig
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

